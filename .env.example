# Broker APIs
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# LLM APIs (fallback chain: Groq 70b → Cerebras 70b → Groq 120b → Cerebras 120b)
GROQ_API_KEY=your_groq_api_key
CEREBRAS_API_KEY=your_cerebras_api_key
# / DeepSeek V4 is used by the evolution mutator
DEEPSEEK_API_KEY=your_deepseek_api_key
# / optional model overrides (default: rolling deepseek aliases)
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER=deepseek-reasoner
# / Anthropic is legacy; kept for optional fallback only
ANTHROPIC_API_KEY=
# / weighted primary-provider split for the 4-tier chain (format: "provider:weight,...")
# / keeps the cerebras fallback warm so we discover latency/quality problems before an incident
# / empty or missing = pure groq (no routing change). unknown provider names are skipped with a warn.
LLM_PROVIDER_SPLIT=groq:0.9,cerebras:0.1

# / Ollama for local embeddings (phase 2 knowledge base)
OLLAMA_BASE_URL=http://localhost:11434

# SEC EDGAR (required — use your real name and email)
SEC_EDGAR_USER_AGENT=YourName your@email.com

# Database (VPS Postgres — local or remote, pgvector extension required)
DATABASE_URL=postgresql://user:pass@host:5432/quant_trading?sslmode=disable

# Risk Limits (most limits live in configs/risk_limits.json)
MAX_POSITION_PCT=0.08
MAX_PORTFOLIO_RISK=0.25

# Trading
LONG_ONLY=true
# / optional explicit universe — comma-separated. empty = FULL_UNIVERSE from src/data/symbols.py
TRADE_SYMBOLS=

# Logging
LOG_LEVEL=INFO

# Notifications (optional — any combination)
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_TRADES=
DISCORD_WEBHOOK_ANALYSIS=
DISCORD_WEBHOOK_STRATEGY=
DISCORD_WEBHOOK_DAILY=
DISCORD_WEBHOOK_SENTIMENT=
DISCORD_WEBHOOK_SYSTEM=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Data sources (optional — missing = skip silently)
FINNHUB_API_KEY=
FRED_API_KEY=
DUNE_API_KEY=
DUNE_QUERY_ACTIVE_ADDRESSES=0
DUNE_QUERY_EXCHANGE_FLOWS=0
DUNE_QUERY_WHALE_TRANSACTIONS=0

# Dashboard
DASHBOARD_PORT=8000
DASHBOARD_HOST=127.0.0.1
# / optional CORS allowlist, comma-separated. empty = allow all
ALPHALOOP_CORS_ORIGINS=
# / admin endpoints (/api/admin/trigger/{service}) — required. if unset, the
# / endpoints return 503 instead of running open. suggest 32+ char random value.
ADMIN_TOKEN=

# Phase 2: Knowledge base thresholds
POST_MORTEM_PNL_ABS=50
POST_MORTEM_PNL_PCT=0.02
POST_MORTEM_COOLDOWN_HOURS=24
# / evolution loop: fraction of mutations that use wiki context (0.0 - 1.0)
WIKI_GUIDED_RATIO=0.80
# / phase 5 step 3: cap on daily symbol wiki enrichments (llm budget guard)
WIKI_HYDRATION_DAILY_CAP=5
